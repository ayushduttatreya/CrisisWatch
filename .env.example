# CrisisWatch Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: NewsAPI Key
# Get your free API key from: https://newsapi.org/register
# =============================================================================
NEWS_API_KEY=your_newsapi_key_here

# =============================================================================
# OPTIONAL: Database Configuration
# =============================================================================
# Local development (relative path)
DATABASE_PATH=crisiswatch.db

# Docker production (absolute path inside container)
# DATABASE_PATH=/app/data/crisiswatch.db

# =============================================================================
# OPTIONAL: Scheduler Configuration
# =============================================================================
# How often to fetch news (in seconds)
# 600 = 10 minutes, 300 = 5 minutes, 1800 = 30 minutes
REFRESH_INTERVAL=600

# =============================================================================
# OPTIONAL: Flask Configuration
# =============================================================================
# Server port (default: 5000)
PORT=5000

# Debug mode (true/false) - disable in production
FLASK_DEBUG=false

# =============================================================================
# OPTIONAL: News Source Configuration
# =============================================================================
# Comma-separated list of NewsAPI categories to fetch
NEWS_CATEGORIES=general,business,world,technology,health

# =============================================================================
# OPTIONAL: Advanced Trend Analysis
# =============================================================================
# Number of data points in rolling window (default: 60)
TREND_WINDOW_SIZE=60

# Crisis detection threshold (default: -0.3)
# Lower = more sensitive to negative news spikes
SPIKE_THRESHOLD=-0.3

# =============================================================================
# OPTIONAL: AI Intelligence Layer (OpenRouter)
# =============================================================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# AI model to use (default: anthropic/claude-3.5-haiku)
# Other options: openai/gpt-4o-mini, google/gemini-flash-1.5, etc.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Request timeout in seconds (default: 30)
OPENROUTER_TIMEOUT=30

# Max concurrent AI calls (default: 5)
OPENROUTER_MAX_CONCURRENT=5

# Enable/disable AI features
AI_ENABLED=true
AI_ENTITY_EXTRACTION=true
AI_BIAS_DETECTION=true
AI_CRISIS_SUMMARY=true
